# Google AdSense — preencha depois de criar a conta e aprovar o site.
# Defina estas variáveis também na Vercel (Project Settings -> Environment
# Variables) e refaça o deploy. Enquanto estiverem vazias, o site mostra
# placeholders no lugar dos anúncios.

# Publisher ID do AdSense (aparece como "ca-pub-XXXXXXXXXXXXXXXX").
NEXT_PUBLIC_ADSENSE_CLIENT=

# Slot IDs numéricos de cada bloco de anúncio criado no AdSense.
# Trilho lateral direito (300x600), visível só em telas grandes.
NEXT_PUBLIC_ADSENSE_SLOT_RAIL=
# Banner no rodapé do conteúdo (728x90).
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=
